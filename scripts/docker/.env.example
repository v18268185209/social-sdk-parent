# ============================================================================
# 环境变量配置 — 闲鱼管理器 Docker
#
# 复制此文件为 .env 并修改值：
#   cp .env.example .env
#
# 通过 docker compose --env-file .env 加载
# ============================================================================

# ── 应用配置 ───────────────────────────────────────────────────────────────
# 应用端口（宿主机映射）
APP_PORT=8080

# JWT 密钥（生产环境必须修改为强随机字符串！）
XIANYU_JWT_SECRET=please-change-me-to-a-random-string-min-32-chars

# Cookie 加密密钥
XIANYU_CRYPTO_SECRET=please-change-me-to-another-random-string

# ── MySQL 配置（仅 DB_MODE=mysql 时生效） ──────────────────────────────────
# MySQL 暴露端口
MYSQL_PORT=3306

# MySQL root 密码
MYSQL_ROOT_PASSWORD=root123456

# MySQL 应用用户密码
MYSQL_PASSWORD=xianyu123456

# ── JVM 配置 ───────────────────────────────────────────────────────────────
JAVA_OPTS=-Xmx512m -Xms256m

# ── 数据目录（宿主机路径） ─────────────────────────────────────────────────
DATA_DIR=./data
CHROME_PROFILES_DIR=./chrome-profiles
LOGS_DIR=./logs
CONFIG_DIR=./config

# ── 镜像仓库（推送到远程仓库时配置） ───────────────────────────────────────
# REGISTRY=registry.example.com/xianyu
# TAG=latest
