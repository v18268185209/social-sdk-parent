# ============================================================================
# 闲鱼管理器 Docker 一键启动配置
# ============================================================================
# 使用方法：
#   1. 复制本文件为 .env
#      Windows PowerShell:  copy .env.example .env
#      Linux/macOS:         cp .env.example .env
#
#   2. 选择一种数据库启动：
#      SQLite（最简单，推荐新手）：
#        docker compose --env-file .env -f docker-compose.yml up -d
#
#      MySQL：
#        docker compose --env-file .env -f docker-compose.yml -f docker-compose.mysql.yml up -d
#
#      PostgreSQL：
#        docker compose --env-file .env -f docker-compose.yml -f docker-compose.postgres.yml up -d
#
#   3. 浏览器访问：
#      http://服务器IP:8080
#      本机访问：http://localhost:8080
#
#   4. 查看日志：
#      docker compose --env-file .env -f docker-compose.yml logs -f
#
#   5. 停止服务：
#      docker compose --env-file .env -f docker-compose.yml down
#      MySQL 停止：docker compose --env-file .env -f docker-compose.yml -f docker-compose.mysql.yml down
#      PostgreSQL 停止：docker compose --env-file .env -f docker-compose.yml -f docker-compose.postgres.yml down
# ============================================================================

# ----------------------------------------------------------------------------
# 1. 应用端口
# ----------------------------------------------------------------------------
# 宿主机访问端口。默认 8080，即 http://服务器IP:8080
# 如果 8080 被占用，改成 18080，然后访问 http://服务器IP:18080
APP_PORT=8080

# ----------------------------------------------------------------------------
# 2. 安全密钥
# ----------------------------------------------------------------------------
# 傻瓜式启动可以先不改；正式生产部署必须改成随机长字符串。
# 注意：已上线使用后不要随便改，否则旧 token/cookie 可能失效。
XIANYU_JWT_SECRET=xianyu-manager-jwt-secret-change-me-please-2026
XIANYU_CRYPTO_SECRET=xianyu-manager-crypto-secret-change-me-please-2026

# ----------------------------------------------------------------------------
# 3. 数据库模式选择说明
# ----------------------------------------------------------------------------
# 普通用户直接用 docker compose 时，通过 -f 选择数据库：
#   SQLite:      -f docker-compose.yml
#   MySQL:       -f docker-compose.yml -f docker-compose.mysql.yml
#   PostgreSQL:  -f docker-compose.yml -f docker-compose.postgres.yml
# 开发者从源码构建时，才需要叠加 -f docker-compose.build.yml，并使用 DB_MODE 指定构建模式。
# 可选值：sqlite / mysql / postgres
DB_MODE=sqlite

# ----------------------------------------------------------------------------
# 4. SQLite 配置（默认推荐，新手无需改）
# ----------------------------------------------------------------------------
# SQLite 数据保存在宿主机 scripts/docker/data 目录下。
# 容器内数据库文件固定为 /app/data/xianyu-manager.db。
SQLITE_DB_PATH=/app/data/xianyu-manager.db

# ----------------------------------------------------------------------------
# 5. MySQL 配置（仅 MySQL 启动方式生效）
# ----------------------------------------------------------------------------
# MySQL 宿主机端口。默认 3306；如果本机已有 MySQL，可改为 13306。
MYSQL_PORT=3306

# MySQL root 密码。
MYSQL_ROOT_PASSWORD=root123456

# 应用连接 MySQL 的普通用户密码。
MYSQL_PASSWORD=xianyu123456

# MySQL 数据库名和用户名。一般不用改，需与 docker-compose.mysql.yml 保持一致。
MYSQL_DATABASE=xianyu_manager
MYSQL_USER=xianyu

# ----------------------------------------------------------------------------
# 6. PostgreSQL 配置（仅 PostgreSQL 启动方式生效）
# ----------------------------------------------------------------------------
# PostgreSQL 宿主机端口。默认 5432；如果本机已有 PostgreSQL，可改为 15432。
POSTGRES_PORT=5432

# PostgreSQL 应用用户密码。
POSTGRES_PASSWORD=xianyu123456

# PostgreSQL 数据库名和用户名。一般不用改，需与 docker-compose.postgres.yml 保持一致。
POSTGRES_DB=xianyu_manager
POSTGRES_USER=xianyu

# ----------------------------------------------------------------------------
# 7. JVM 配置
# ----------------------------------------------------------------------------
# 小机器默认 512m 足够；如果商品/订单很多，可改为 -Xmx1024m -Xms512m。
JAVA_OPTS=-Xmx512m -Xms256m

# ----------------------------------------------------------------------------
# 8. Chrome/浏览器配置
# ----------------------------------------------------------------------------
# Docker/Linux 环境必须无头运行，不建议改 false。
CHROME_HEADLESS=true
CHROME_HEADLESS_MODE=new

# ----------------------------------------------------------------------------
# 9. 数据目录说明
# ----------------------------------------------------------------------------
# 当前 compose 默认使用 scripts/docker 目录下的这些文件夹：
#   ./data              SQLite 数据库、上传文件等
#   ./chrome-profiles   浏览器登录态/用户数据
#   ./logs              应用日志
#   ./config            外部配置
#
# 下面变量预留给自定义 compose/脚本使用；默认 compose 当前不依赖它们。
DATA_DIR=./data
CHROME_PROFILES_DIR=./chrome-profiles
LOGS_DIR=./logs
CONFIG_DIR=./config

# ----------------------------------------------------------------------------
# 10. 镜像配置（普通启动会用下面的 ACR 公开镜像）
# ----------------------------------------------------------------------------
# 默认镜像：registry.cn-hangzhou.aliyuncs.com/eqadmin/xianyu-manager:sqlite-0.0.2
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ACR_NAMESPACE=eqadmin
IMAGE_NAME=xianyu-manager
TAG=0.0.2

# 如果 ACR 改成私有仓库，才需要登录或配置下面两个变量给 publish-acr 脚本使用。
# ACR_USERNAME=your-username
# ACR_PASSWORD=your-password

# 兼容旧 build.sh 的 REGISTRY 写法，例如：registry.example.com/xianyu
# REGISTRY=registry.example.com/xianyu

# ----------------------------------------------------------------------------
# 11. 常用命令速查
# ----------------------------------------------------------------------------
# SQLite 启动（默认会从 ACR 拉取镜像，不需要 Dockerfile）：
#   docker compose --env-file .env -f docker-compose.yml up -d
#
# MySQL 启动：
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose.mysql.yml up -d
#
# PostgreSQL 启动：
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose.postgres.yml up -d
#
# 查看状态：
#   docker compose --env-file .env -f docker-compose.yml ps
#
# 查看日志：
#   docker compose --env-file .env -f docker-compose.yml logs -f
#
# 健康检查：
#   curl http://localhost:8080/api/system/health
#
# 重新拉取并重启 ACR 镜像：
#   docker compose --env-file .env -f docker-compose.yml pull
#   docker compose --env-file .env -f docker-compose.yml up -d --force-recreate
#
# 开发者从源码重新构建：
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose.build.yml up -d --build --force-recreate
# ============================================================================
